# AIOS console — intelligence layer (ALL OPT-IN).
#
# Copy to `aios/.env` and fill in only what you want to enable. With NO .env the
# console runs exactly as v1: BM25 lexical search + the search-panel Assistant.
# The middleware loads this file with a tiny no-dep parser; values already set in
# the real environment win.

# ── The agent (BYO key) ──────────────────────────────────────────────────────
# Set ANTHROPIC_API_KEY to turn the Assistant into a streaming chat agent.
# With no key, /api/assistant/chat returns { disabled:true } and the UI shows
# the search panel. Model defaults to claude-sonnet-4-6.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Embeddings (semantic search) ─────────────────────────────────────────────
# EMBEDDINGS=local  → try the optional local model (@xenova/transformers,
#                     all-MiniLM-L6-v2, 384-dim); falls back to BM25 if not
#                     installed (run `npm run kb:enable-local-embeddings`).
# EMBEDDINGS=openai → OpenAI text-embedding-3-small (1536-dim); needs OPENAI_API_KEY.
# EMBEDDINGS=none   → pure BM25 (zero extra deps; the out-of-the-box default path).
EMBEDDINGS=local
OPENAI_API_KEY=

# ── Knowledge store ──────────────────────────────────────────────────────────
# KB_STORE=local    → JSON index under aios/.kb-index/ (default).
# KB_STORE=supabase → pgvector via Supabase; ACTIVE only when BOTH vars below are
#                     set (otherwise it silently falls back to local).
KB_STORE=local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Design — Google Stitch MCP (BYO key; optional) ───────────────────────────
# Set STITCH_API_KEY (a Google AI / Gemini key) to let the `define-design` skill
# drive the Google Stitch MCP directly (also set "mcp_enabled": true in that
# skill's config.json). With no key, define-design uses the manual paste-back
# path. Privacy: the MCP sends prompts + any uploaded screenshots to Google —
# see docs/DESIGN-SYSTEM.md.
STITCH_API_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────
# PROJECT_TYPE describes this clone to the agent (mirrors src/config/project.ts).
# PROJECT_TYPE=general
